# ~/.denrc — Den shell startup script
#
# Den sources this file line-by-line as shell commands at startup (like .zshrc).
# Environment + $PATH live in env.sh and aliases in aliases.sh — both shared with
# the zsh fallback so there is a single source of truth. Prompt, syntax
# highlighting, autosuggestions, completion and history search are configured
# declaratively in ~/.config/den.jsonc (Den provides them natively — no
# oh-my-zsh, no starship, no cloned zsh plugins).
#
# Symlinked from ~/.dotfiles/.denrc to ~/.denrc by ./fresh.sh.
# Reload after edits with:  reloadshell   (aliased to `exec $SHELL`)

source $HOME/.dotfiles/env.sh
source $HOME/.dotfiles/aliases.sh
