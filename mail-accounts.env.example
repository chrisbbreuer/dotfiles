# mail-accounts.env — credentials for `bun run mail` (bin/mail-profile).
#
# Copy to ~/.config/mail-accounts.env and fill in. This file holds plaintext
# passwords: keep it OUT of git (it lives in ~/.config) — it's synced to iCloud
# by ts-backups instead. One block per account, grouped by an uppercase PREFIX;
# `<PREFIX>_EMAIL` defines the account.
#
# Two kinds of account:
#   1. Pre-filled  — a password is given, so it goes into a config profile and
#      sets itself up (one approval click). Use for custom IMAP/SMTP and Gmail
#      with an app password.
#   2. Interactive — no password (or `<PREFIX>_INTERACTIVE=true`). `bun run mail`
#      just opens System Settings → Internet Accounts and tells you to sign in
#      once. Use for Gmail (OAuth) and iCloud, where you only enter the password.

# ── Pre-filled: custom IMAP/SMTP (full control over servers) ─────────────────
WORK_EMAIL=chris@company.com
WORK_USERNAME=chris               # optional, defaults to the email
WORK_PASSWORD=your-password
WORK_NAME=Chris Breuer            # display name (optional)
WORK_IMAP_HOST=imap.company.com
WORK_IMAP_PORT=993               # optional, default 993
WORK_SMTP_HOST=smtp.company.com
WORK_SMTP_PORT=465               # optional, default 587

# ── Pre-filled: Gmail with an APP PASSWORD (servers preset) ──────────────────
# Google account → Security → 2-Step Verification → App passwords. Omit the
# password (or set GMAIL_INTERACTIVE=true) to sign in via OAuth instead.
# GMAIL_EMAIL=you@gmail.com
# GMAIL_PASSWORD=your-16-char-app-password

# ── Interactive: Gmail via OAuth (you enter the password once) ───────────────
GOOGLE_EMAIL=you@gmail.com
GOOGLE_INTERACTIVE=true

# ── Interactive: iCloud (auto — rides your Apple ID) ─────────────────────────
ICLOUD_EMAIL=you@icloud.com
