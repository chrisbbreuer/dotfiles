# mail-accounts.env — credentials for `bun run mail` (bin/mail-profile).
#
# Copy to ~/.config/mail-accounts.env and fill in. This file holds plaintext
# passwords: keep it OUT of git (it lives in ~/.config) — it's synced to iCloud
# by ts-backups instead. One block per account, grouped by an uppercase PREFIX;
# `<PREFIX>_EMAIL` defines the account.
#
# Every account is pre-filled (set up by the profile, no interactive sign-in) as
# long as it has a password. Custom servers take an IMAP/SMTP block; Gmail and
# iCloud just need an email + an APP PASSWORD (servers are preset). An account
# with no password (or `<PREFIX>_INTERACTIVE=true`) falls back to a one-time
# interactive sign-in via System Settings → Internet Accounts.

# ── Custom IMAP/SMTP (full control over servers) ─────────────────────────────
WORK_EMAIL=chris@company.com
WORK_USERNAME=chris@company.com   # optional; defaults to the email. Many servers REQUIRE the full email — use it if a bare name fails to log in
WORK_PASSWORD=your-password
WORK_NAME=Chris Breuer            # display name (optional)
WORK_IMAP_HOST=imap.company.com
WORK_IMAP_PORT=993               # optional, default 993
WORK_SMTP_HOST=smtp.company.com
WORK_SMTP_PORT=465               # optional, default 587

# ── Gmail — email + APP PASSWORD (servers preset; no OAuth) ───────────────────
# myaccount.google.com → Security → 2-Step Verification → App passwords (needs
# 2FA). Leave the password empty to fall back to an interactive Google sign-in.
GMAIL_EMAIL=you@gmail.com
GMAIL_PASSWORD=your-16-char-app-password

# ── iCloud — usually NOT needed ──────────────────────────────────────────────
# Your primary iCloud Mail comes with your Apple ID (System Settings → Apple ID →
# iCloud → iCloud Mail), so iCloud accounts are skipped by default. List one only
# for a SECONDARY iCloud address that isn't your Apple ID — with ICLOUD_FORCE=true
# and an app-specific password (account.apple.com → Sign-In and Security).
# ICLOUD_EMAIL=you@icloud.com
# ICLOUD_FORCE=true
# ICLOUD_PASSWORD=your-app-specific-password
