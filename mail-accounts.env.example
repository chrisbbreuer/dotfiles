# mail-accounts.env — credentials for `bun run mail` (bin/mail-profile).
#
# Copy to ~/.config/mail-accounts.env and fill in. This file holds plaintext
# passwords: keep it OUT of git (it lives in ~/.config) — it's synced to iCloud
# by ts-backups instead. One block per account, grouped by an uppercase PREFIX;
# `<PREFIX>_EMAIL` defines the account.

# Custom IMAP/SMTP — full control over servers.
WORK_EMAIL=chris@company.com
WORK_PASSWORD=your-password
WORK_NAME=Chris Breuer
WORK_IMAP_HOST=imap.company.com
WORK_IMAP_PORT=993
WORK_SMTP_HOST=smtp.company.com
WORK_SMTP_PORT=587
# WORK_USERNAME=chris@company.com   # optional, defaults to the email

# Gmail / Google Workspace — servers are preset (provider auto-detected for
# @gmail.com). Needs an APP PASSWORD (Google account → Security → App passwords),
# because plain-password IMAP is disabled.
GMAIL_EMAIL=you@gmail.com
GMAIL_PASSWORD=your-16-char-app-password

# iCloud Mail (@icloud.com / @me.com / @mac.com) is skipped automatically —
# set it up by signing into your Apple ID (System Settings → iCloud → iCloud Mail).
