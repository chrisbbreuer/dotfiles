#!/bin/sh
# install-zig-dev — install the latest Zig 0.17-dev (master nightly) into
# Pantry's managed store and point Pantry's `zig` shim at it.
#
# Den is built against Zig 0.17-dev. Pantry's `ziglang.org` package currently
# only resolves tagged releases, so this script bridges the gap until nightly
# resolution lands upstream. Idempotent and safe to re-run.
#
# Usage: ./bin/install-zig-dev
set -e

STORE="$HOME/.local/share/pantry/global/pantry_modules"
INDEX_URL="https://ziglang.org/download/index.json"

# Pick a working python3 — the one on PATH may be a stale Pantry shim.
PY=""
for c in /usr/bin/python3 python3 python; do
  if command -v "$c" >/dev/null 2>&1 && "$c" -c 'import json,sys' >/dev/null 2>&1; then
    PY="$c"; break
  fi
done
[ -n "$PY" ] || { echo "no working python3 found (needed to parse the Zig index)" >&2; exit 1; }

# Map uname -> Zig's target naming
arch=$(uname -m)
case "$arch" in
  arm64|aarch64) zarch="aarch64" ;;
  x86_64)        zarch="x86_64" ;;
  *) echo "unsupported arch: $arch" >&2; exit 1 ;;
esac
case "$(uname -s)" in
  Darwin) zos="macos" ;;
  Linux)  zos="linux" ;;
  *) echo "unsupported OS: $(uname -s)" >&2; exit 1 ;;
esac
target="${zarch}-${zos}"

echo "Resolving latest Zig master for ${target}..."
info=$(curl -fsSL "$INDEX_URL" | "$PY" -c "
import json,sys
m=json.load(sys.stdin)['master']
print(m['version'])
print(m['${target}']['tarball'])
")
version=$(printf '%s\n' "$info" | sed -n 1p)
url=$(printf '%s\n' "$info" | sed -n 2p)
[ -n "$version" ] && [ -n "$url" ] || { echo "could not resolve master build" >&2; exit 1; }

dest="$STORE/ziglang.org/v${version}"
if [ -x "$dest/bin/zig" ]; then
  echo "Zig $version already installed."
else
  echo "Downloading $url"
  tmp=$(mktemp -d)
  curl -fsSL "$url" -o "$tmp/zig.tar.xz"
  mkdir -p "$tmp/x"
  tar -xf "$tmp/zig.tar.xz" -C "$tmp/x" --strip-components=1
  rm -rf "$dest"
  mkdir -p "$dest/bin"
  mv "$tmp/x/zig" "$dest/bin/zig"
  mv "$tmp/x/lib" "$dest/lib"
  [ -d "$tmp/x/doc" ] && mv "$tmp/x/doc" "$dest/doc" || true
  for f in LICENSE README.md; do [ -f "$tmp/x/$f" ] && mv "$tmp/x/$f" "$dest/$f" || true; done
  chmod +x "$dest/bin/zig"
  rm -rf "$tmp"
fi

# Point Pantry's shim at the dev build
mkdir -p "$STORE/.bin"
ln -sf "../ziglang.org/v${version}/bin/zig" "$STORE/.bin/zig"

echo "Installed and activated: $("$dest/bin/zig" version)"
echo "Ensure \$HOME/.local/share/pantry/global/pantry_modules/.bin is on PATH (it is in .denrc)."
