#!/usr/bin/env bun
/**
 * mail-profile — generate a macOS configuration profile (.mobileconfig) that
 * sets up your Mail.app accounts from a .env of credentials, then open it for
 * the (one-time) approval click.
 *
 *   bun run mail                      # uses ~/.config/mail-accounts.env
 *   ./bin/mail-profile path/to.env    # explicit env file
 *   MAIL_ENV=… ./bin/mail-profile     # or via env var
 *   ./bin/mail-profile --bundle       # one combined profile instead of one-per-account
 *   ./bin/mail-profile --print        # write + print the path(s), don't open
 *
 * Why a profile? macOS has no supported CLI to create a Mail account directly;
 * a `com.apple.mail.managed` configuration profile is the clean, scriptable way
 * to define IMAP/SMTP accounts (servers, ports, SSL, username, password). On a
 * non-MDM Mac a profile can't install silently — macOS stages it and you approve
 * it in System Settings → General → Device Management.
 *
 * By default each account becomes its OWN profile, so you can remove any single
 * account later (System Settings → Device Management → select it → Remove)
 * without touching the rest — at the cost of one approval click per account.
 * `--bundle` puts every account in one profile instead: a single approval, but
 * removal is all-or-nothing (removing the profile deletes every account in it).
 *
 * Either way, profile-managed accounts can't be deleted from Mail's own UI — the
 * profile is the unit of removal. To change or drop an account, edit the .env and
 * re-run; re-installing reconciles the matching profile(s) in place.
 *
 * The generated .mobileconfig contains plaintext passwords — treat it like the
 * .env: it rides your iCloud backup, never this public repo. Delete it after the
 * profile is installed.
 *
 * .env format — one block per account, grouped by an uppercase PREFIX. The
 * presence of `<PREFIX>_EMAIL` defines an account:
 *
 *   # Custom IMAP/SMTP (full control)
 *   WORK_EMAIL=chris@company.com
 *   WORK_PASSWORD=app-or-account-password
 *   WORK_NAME=Chris Breuer            # display name (optional)
 *   WORK_IMAP_HOST=imap.company.com
 *   WORK_IMAP_PORT=993               # optional, default 993
 *   WORK_SMTP_HOST=smtp.company.com
 *   WORK_SMTP_PORT=587               # optional, default 587
 *   WORK_USERNAME=chris@company.com  # optional, defaults to the email
 *
 *   # Gmail / Google Workspace — servers are preset; needs an APP PASSWORD
 *   # (Google account → Security → 2-Step Verification → App passwords), since
 *   # plain-password IMAP is disabled. Provider is auto-detected for @gmail.com.
 *   GMAIL_EMAIL=me@gmail.com
 *   GMAIL_PASSWORD=app-password
 *
 * iCloud Mail (@icloud.com / @me.com / @mac.com) is skipped: it comes with your
 * Apple ID (System Settings → Apple ID → iCloud → iCloud Mail), no profile needed.
 * Set <PREFIX>_FORCE=true to include a secondary iCloud address that isn't your Apple ID.
 */
import { createHash } from 'node:crypto'
import { existsSync, readFileSync, writeFileSync } from 'node:fs'
import { homedir, tmpdir } from 'node:os'
import { join } from 'node:path'
import { spawnSync } from 'node:child_process'

const HOME = homedir()
const PROFILE_ID = 'com.chrisbreuer.dotfiles.mail'

// Provider presets keyed by an explicit `<PREFIX>_PROVIDER` or the email domain.
// Server presets so Gmail/iCloud only need an email + an app password to be
// fully pre-filled (no OAuth, no interactive sign-in).
const PRESETS: Record<string, { imapHost: string, imapPort: number, smtpHost: string, smtpPort: number }> = {
  gmail: { imapHost: 'imap.gmail.com', imapPort: 993, smtpHost: 'smtp.gmail.com', smtpPort: 587 },
  icloud: { imapHost: 'imap.mail.me.com', imapPort: 993, smtpHost: 'smtp.mail.me.com', smtpPort: 587 },
}

// Email domains recognised as iCloud (for the preset + interactive fallback).
const ICLOUD_DOMAINS = ['icloud.com', 'me.com', 'mac.com']

interface Account {
  prefix: string
  label: string
  name: string
  email: string
  username: string
  password: string
  imapHost: string
  imapPort: number
  smtpHost: string
  smtpPort: number
}

function fail(msg: string): never {
  console.error(`✖ ${msg}`)
  process.exit(1)
}

/** Parse a .env: KEY=VALUE, `#` comments, optional quotes, `export ` prefix. */
function parseEnv(text: string): Record<string, string> {
  const out: Record<string, string> = {}
  for (let line of text.split('\n')) {
    line = line.trim()
    if (!line || line.startsWith('#')) continue
    if (line.startsWith('export ')) line = line.slice(7).trim()
    const eq = line.indexOf('=')
    if (eq === -1) continue
    const key = line.slice(0, eq).trim()
    let val = line.slice(eq + 1).trim()
    if ((val.startsWith('"') && val.endsWith('"')) || (val.startsWith('\'') && val.endsWith('\''))) {
      val = val.slice(1, -1)
    }
    out[key] = val
  }
  return out
}

/** Deterministic UUID (v5-ish) from a string, so re-runs update — not duplicate. */
function stableUuid(seed: string): string {
  const h = createHash('md5').update(seed).digest('hex')
  return `${h.slice(0, 8)}-${h.slice(8, 12)}-${h.slice(12, 16)}-${h.slice(16, 20)}-${h.slice(20, 32)}`.toUpperCase()
}

function providerFor(env: Record<string, string>, prefix: string, email: string): string | null {
  const explicit = env[`${prefix}_PROVIDER`]?.toLowerCase()
  if (explicit) return explicit
  const domain = email.split('@')[1]?.toLowerCase() ?? ''
  if (domain === 'gmail.com' || domain === 'googlemail.com') return 'gmail'
  if (ICLOUD_DOMAINS.includes(domain)) return 'icloud'
  return null
}

/** An account macOS must set up interactively (OAuth / Apple ID) — we can't
 * pre-seed a password, so we just point the user at the right pane to sign in. */
interface Interactive {
  email: string
  kind: 'google' | 'icloud' | 'manual'
}

const truthy = (v: string | undefined) => !!v && ['1', 'true', 'yes', 'y', 'on'].includes(v.toLowerCase())

function collectAccounts(env: Record<string, string>): { profile: Account[], interactive: Interactive[], skipped: string[] } {
  const profile: Account[] = []
  const interactive: Interactive[] = []
  const skipped: string[] = []

  for (const key of Object.keys(env)) {
    const m = key.match(/^([A-Z0-9]+)_EMAIL$/)
    if (!m) continue
    const prefix = m[1]
    const email = env[key].trim()
    if (!email) continue

    const provider = providerFor(env, prefix, email)

    // iCloud Mail comes with your Apple ID: once you're signed in (System
    // Settings → Apple ID → iCloud → iCloud Mail) the account is already in
    // Mail.app, so there's nothing to provision. Skip it — and never let a stale
    // app-specific password here fail the whole (atomic) profile install. Set
    // <PREFIX>_FORCE=true only for a secondary iCloud address that isn't your Apple ID.
    if (provider === 'icloud' && !truthy(env[`${prefix}_FORCE`])) {
      skipped.push(email)
      continue
    }
    // Gmail/iCloud app passwords are displayed in readable groups — Gmail with
    // spaces (`cqmm udvb …`), iCloud with dashes (`abcd-efgh-…`). Strip spaces so
    // the Gmail one works pasted either way; iCloud's dashes are part of it, kept.
    const rawPassword = env[`${prefix}_PASSWORD`] ?? ''
    const password = (provider === 'gmail' || provider === 'icloud')
      ? rawPassword.replace(/ /g, '')
      : rawPassword
    const wantInteractive = truthy(env[`${prefix}_INTERACTIVE`])

    // Prefer pre-filling: with a password (incl. a Gmail/iCloud app password) the
    // account goes into the profile and sets itself up. Only fall back to an
    // interactive sign-in when there's no password, or it's explicitly forced.
    if (wantInteractive || !password) {
      const kind = provider === 'gmail' ? 'google' : provider === 'icloud' ? 'icloud' : 'manual'
      interactive.push({ email, kind })
      continue
    }

    // Password present → a fully pre-filled profile account.
    const preset = provider ? PRESETS[provider] : undefined
    const imapHost = env[`${prefix}_IMAP_HOST`] ?? preset?.imapHost
    const smtpHost = env[`${prefix}_SMTP_HOST`] ?? preset?.smtpHost
    if (!imapHost) fail(`${prefix}: no ${prefix}_IMAP_HOST and no known provider preset (set ${prefix}_PROVIDER or the host)`)
    if (!smtpHost) fail(`${prefix}: no ${prefix}_SMTP_HOST and no known provider preset`)

    profile.push({
      prefix,
      label: env[`${prefix}_LABEL`] ?? prefix.charAt(0) + prefix.slice(1).toLowerCase(),
      name: env[`${prefix}_NAME`] ?? email,
      email,
      username: env[`${prefix}_USERNAME`] ?? email,
      password,
      imapHost,
      imapPort: Number(env[`${prefix}_IMAP_PORT`] ?? preset?.imapPort ?? 993),
      smtpHost,
      smtpPort: Number(env[`${prefix}_SMTP_PORT`] ?? preset?.smtpPort ?? 587),
    })
  }
  return { profile, interactive, skipped }
}

const xml = (s: string) => s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;')

function mailPayload(a: Account): string {
  const uuid = stableUuid(`${PROFILE_ID}.${a.prefix}.${a.email}`)
  return `    <dict>
      <key>PayloadType</key><string>com.apple.mail.managed</string>
      <key>PayloadVersion</key><integer>1</integer>
      <key>PayloadIdentifier</key><string>${PROFILE_ID}.${a.prefix.toLowerCase()}</string>
      <key>PayloadUUID</key><string>${uuid}</string>
      <key>PayloadDisplayName</key><string>Mail: ${xml(a.email)}</string>
      <key>EmailAccountType</key><string>EmailTypeIMAP</string>
      <key>EmailAccountDescription</key><string>${xml(a.label)}</string>
      <key>EmailAccountName</key><string>${xml(a.name)}</string>
      <key>EmailAddress</key><string>${xml(a.email)}</string>
      <key>IncomingMailServerHostName</key><string>${xml(a.imapHost)}</string>
      <key>IncomingMailServerPortNumber</key><integer>${a.imapPort}</integer>
      <key>IncomingMailServerUseSSL</key><true/>
      <key>IncomingMailServerUsername</key><string>${xml(a.username)}</string>
      <key>IncomingMailServerAuthentication</key><string>EmailAuthPassword</string>
      <key>IncomingPassword</key><string>${xml(a.password)}</string>
      <key>OutgoingMailServerHostName</key><string>${xml(a.smtpHost)}</string>
      <key>OutgoingMailServerPortNumber</key><integer>${a.smtpPort}</integer>
      <key>OutgoingMailServerUseSSL</key><true/>
      <key>OutgoingMailServerUsername</key><string>${xml(a.username)}</string>
      <key>OutgoingMailServerAuthentication</key><string>EmailAuthPassword</string>
      <key>OutgoingPasswordSameAsIncomingPassword</key><true/>
      <key>PreventAppSheet</key><false/>
      <key>PreventMove</key><false/>
      <key>SMIMEEnabled</key><false/>
    </dict>`
}

function buildProfile(accounts: Account[], id: string, displayName: string): string {
  // UUID keyed on the (stable) profile id, not the account set, so re-installing
  // reconciles the matching profile in place rather than spawning a duplicate.
  const uuid = stableUuid(id)
  return `<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>PayloadType</key><string>Configuration</string>
  <key>PayloadVersion</key><integer>1</integer>
  <key>PayloadIdentifier</key><string>${id}</string>
  <key>PayloadUUID</key><string>${uuid}</string>
  <key>PayloadDisplayName</key><string>${xml(displayName)}</string>
  <key>PayloadDescription</key><string>IMAP/SMTP mail accounts generated from your dotfiles .env.</string>
  <key>PayloadOrganization</key><string>dotfiles</string>
  <key>PayloadScope</key><string>User</string>
  <key>PayloadRemovalDisallowed</key><false/>
  <key>PayloadContent</key>
  <array>
${accounts.map(mailPayload).join('\n')}
  </array>
</dict>
</plist>
`
}

// ── main ─────────────────────────────────────────────────────────────────────
const args = process.argv.slice(2)
const printOnly = args.includes('--print')
const bundle = args.includes('--bundle')
const envPath = args.find(a => !a.startsWith('--')) ?? process.env.MAIL_ENV ?? join(HOME, '.config/mail-accounts.env')

if (!existsSync(envPath)) {
  fail(`No mail env file at ${envPath}\n  Create one (see bin/mail-profile header or mail-accounts.env.example), or pass a path.`)
}

const INTERNET_ACCOUNTS = 'x-apple.systempreferences:com.apple.Internet-Accounts-Settings.extension'

const env = parseEnv(readFileSync(envPath, 'utf8'))
const { profile, interactive, skipped } = collectAccounts(env)
if (profile.length === 0 && interactive.length === 0 && skipped.length === 0)
  fail('No accounts found (need at least one <PREFIX>_EMAIL).')

if (skipped.length > 0)
  console.error(`ℹ Skipped iCloud (already in Mail via your Apple ID): ${skipped.join(', ')}`)

// 1. Pre-filled accounts → configuration profile(s) with servers + passwords.
//    Default: one profile per account, so any single account can be removed on
//    its own in System Settings → Device Management. `--bundle` packs them into
//    one profile instead (one approval click, but removal is all-or-nothing).
if (profile.length > 0) {
  const builds = bundle
    ? [{
        path: join(tmpdir(), 'mail-accounts.mobileconfig'),
        content: buildProfile(profile, PROFILE_ID, `Mail Accounts (${profile.length})`),
        label: profile.map(a => a.email).join(', '),
      }]
    : profile.map(a => ({
        path: join(tmpdir(), `mail-${a.prefix.toLowerCase()}.mobileconfig`),
        content: buildProfile([a], `${PROFILE_ID}.${a.prefix.toLowerCase()}.profile`, `Mail: ${a.email}`),
        label: a.email,
      }))

  for (const b of builds) {
    writeFileSync(b.path, b.content, { mode: 0o600 })
    console.error(`✓ Profile — ${b.label}`)
    console.error(`  ${b.path}`)
  }

  if (printOnly) {
    for (const b of builds) console.log(b.path)
  }
  else {
    for (const b of builds) spawnSync('open', [b.path], { stdio: 'ignore' })
    const many = builds.length > 1
    console.error(`  → approve ${many ? 'each one' : 'it'}: System Settings → General → Device Management.`)
    if (many)
      console.error('    (if only one shows at a time, approve it then re-open the next path above with `open`)')
    console.error(`  Then delete the file${many ? 's' : ''} — ${many ? 'they hold' : 'it holds'} plaintext passwords.`)
  }
}

// 2. Interactive accounts (Gmail OAuth / iCloud / Apple ID) → just open Internet
//    Accounts and tell the user which to add. The only manual password entry.
if (interactive.length > 0) {
  console.error(`\nSign in to these by hand (one password each):`)
  for (const a of interactive) {
    const how = a.kind === 'google'
      ? 'add a Google account'
      : a.kind === 'icloud'
        ? 'add an iCloud account (or sign into this Apple ID)'
        : 'add the account manually'
    console.error(`  • ${a.email} — ${how}`)
  }
  if (!printOnly) {
    spawnSync('open', [INTERNET_ACCOUNTS], { stdio: 'ignore' })
    console.error('  (opened System Settings → Internet Accounts)')
  }
}
